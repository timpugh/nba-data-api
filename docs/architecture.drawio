        <mxCell id="step-4-desc" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Browser telemetry&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;CloudWatch RUM ingests page-load, JS-error, and fetch-latency events; X-Ray segment headers correlate client to backend traces.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-4-legend">
          <mxGeometry x="52" width="548" height="80" as="geometry" />
        </mxCell>

