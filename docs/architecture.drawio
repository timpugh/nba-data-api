        <mxCell id="step-1-desc" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Static asset delivery&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Browser loads the SPA from CloudFront, which fetches the bundle from a CMK-encrypted S3 origin via OAC.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-1-legend">
          <mxGeometry x="52" width="548" height="80" as="geometry" />
        </mxCell>

        <!-- Step 2: WAF -->
        <mxCell id="step-2-legend" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry y="90" width="600" height="80" as="geometry" />
        </mxCell>
        <mxCell id="step-2-badge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="2" vertex="1" parent="step-2-legend">
          <mxGeometry y="2" width="40" height="38" as="geometry" />
        </mxCell>
        <mxCell id="step-2-desc" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;WAF inspection on every request&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;CloudFront has a WebACL attached: IP reputation, CRS, known-bad-inputs, anonymous-IP, plus a forwarded-IP rate limit.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-2-legend">
          <mxGeometry x="52" width="548" height="80" as="geometry" />
        </mxCell>

        <!-- Step 3: Cognito guest auth -->
