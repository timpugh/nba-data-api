        <mxCell id="step-6-desc" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Lambda invocation&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;API Gateway proxies to a Python 3.13 arm64 Lambda; Powertools handles routing, logging, metrics, and idempotency.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-6-legend">
          <mxGeometry x="52" width="548" height="80" as="geometry" />
