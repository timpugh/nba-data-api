        <mxCell id="step-7-desc" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Idempotency record&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Lambda reads/writes the Idempotency-Key in DynamoDB to short-circuit retries; PITR enabled, encryption with the project CMK.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-7-legend">
          <mxGeometry x="52" width="548" height="80" as="geometry" />
        </mxCell>

